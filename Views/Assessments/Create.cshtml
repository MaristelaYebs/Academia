@{ ViewData["Title"] = "Create Assessment"; }

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4"><i class="fas fa-tasks text-warning me-2"></i>Create Assessment</h5>
                <form asp-action="Create" method="post">
                    <input type="hidden" name="CourseId" value="@ViewBag.CourseId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Title *</label>
                        <input name="Title" class="form-control" required placeholder="e.g. Midterm Quiz" />
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Type</label>
                            <select name="Type" class="form-select">
                                <option>Quiz</option>
                                <option>Assignment</option>
                                <option>Exam</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Max Score</label>
                            <input name="MaxScore" type="number" class="form-control" value="100" min="1" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Due Date</label>
                        <input name="DueDate" type="datetime-local" class="form-control" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="Description" class="form-control" rows="4" placeholder="Instructions..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning text-white"><i class="fas fa-save me-1"></i>Create</button>
                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@ViewBag.CourseId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>