@model EduTrack.Models.Course
@{ ViewData["Title"] = "Delete Course"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-body text-center p-4">
                <i class="fas fa-exclamation-triangle fa-3x text-danger mb-3"></i>
                <h5 class="fw-bold">Delete Course?</h5>
                <p class="text-muted">Are you sure you want to delete <strong>@Model.Title</strong>? This action cannot be undone.</p>
                <div class="d-flex gap-2 justify-content-center">
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-danger"><i class="fas fa-trash me-1"></i>Yes, Delete</button>
                    </form>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>