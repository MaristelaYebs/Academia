@model EduTrack.Models.ViewModels.DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#4e9fc7,#3b86aa)">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div style="font-size:.85rem;opacity:.8">Total Courses</div>
                    <div style="font-size:2rem;font-weight:800">@Model.TotalCourses</div>
                </div>
                <i class="fas fa-book fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#3aa6a0,#2d7d79)">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div style="font-size:.85rem;opacity:.8">Students</div>
                        <div style="font-size:2rem;font-weight:800">@Model.TotalStudents</div>
                    </div>
                    <i class="fas fa-users fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    }
    <div class="col-md-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#ea8b3a,#cf7324)">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div style="font-size:.85rem;opacity:.8">Enrollments</div>
                    <div style="font-size:2rem;font-weight:800">@Model.TotalEnrollments</div>
                </div>
                <i class="fas fa-user-check fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#6b7280,#555c66)">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div style="font-size:.85rem;opacity:.8">Avg Score</div>
                    <div style="font-size:2rem;font-weight:800">@Model.AverageScore.ToString("F1")%</div>
                </div>
                <i class="fas fa-chart-line fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-7">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0"><i class="fas fa-book-open text-primary me-2"></i>Recent Courses</h6>
                    <a asp-controller="Courses" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                @if (!Model.RecentCourses.Any())
                {
                    <p class="text-muted text-center py-3">No courses yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead><tr><th>Course</th><th>Code</th><th>Status</th></tr></thead>
                            <tbody>
                            @foreach (var c in Model.RecentCourses)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@c.Id" class="text-decoration-none fw-semibold">@c.Title</a>
                                        <div class="text-muted" style="font-size:.8rem">@c.Category</div>
                                    </td>
                                    <td>
                                        @if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
                                        {
                                            <span class="badge bg-secondary">@c.CourseCode</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Hidden</span>
                                        }
                                    </td>
                                    <td>
                                        @if (c.IsPublished)
                                        { <span class="badge bg-success">Published</span> }
                                        else
                                        { <span class="badge bg-warning text-dark">Draft</span> }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="fas fa-clock text-warning me-2"></i>Recent Enrollments</h6>
                @if (!Model.RecentEnrollments.Any())
                {
                    <p class="text-muted text-center py-3">No enrollments yet.</p>
                }
                else
                {
                    @foreach (var e in Model.RecentEnrollments)
                    {
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3 flex-shrink-0"
                                 style="width:38px;height:38px;font-size:.85rem">
                                @e.Student?.FullName.Substring(0, 1).ToUpper()
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold" style="font-size:.9rem">@e.Student?.FullName</div>
                                <div class="text-muted" style="font-size:.8rem">@e.Course?.Title</div>
                                <div class="progress mt-1">
                                    <div class="progress-bar bg-success" style="width:@e.Progress%"></div>
                                </div>
                            </div>
                            <div class="ms-2 text-muted" style="font-size:.8rem">@e.Progress.ToString("F0")%</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>