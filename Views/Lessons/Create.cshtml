@{ ViewData["Title"] = "Add Lesson"; }

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4"><i class="fas fa-book-open text-primary me-2"></i>Add Lesson</h5>
                <form asp-action="Create" method="post">
                    <input type="hidden" name="CourseId" value="@ViewBag.CourseId" />
                    <div asp-validation-summary="All" class="alert alert-danger small"></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Lesson Title *</label>
                        <input name="Title" class="form-control" required maxlength="200" placeholder="e.g. Introduction to Variables" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Order</label>
                        <input name="Order" type="number" class="form-control" value="1" min="1" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Content *</label>
                        <textarea name="Content" class="form-control" rows="6" required placeholder="Write lesson content here..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Save Lesson</button>
                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@ViewBag.CourseId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>