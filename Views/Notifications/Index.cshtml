@model IEnumerable<Academia.Models.ViewModels.NotificationItemViewModel>
@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0">Notifications</h5>
    <span class="badge bg-secondary">@Model.Count() updates</span>
</div>

<div class="card">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-bell-slash fa-3x text-muted mb-3"></i>
                <p class="text-muted mb-0">No notifications yet.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <a href="@item.Link" class="text-decoration-none text-reset">
                    <div class="d-flex align-items-start border rounded p-3 mb-2">
                        <div class="me-3 mt-1">
                            @if (item.Type == "Lesson")
                            {
                                <i class="fas fa-book-open text-primary"></i>
                            }
                            else if (item.Type == "Enrollment")
                            {
                                <i class="fas fa-user-check text-success"></i>
                            }
                            else if (item.Type == "Submission")
                            {
                                <i class="fas fa-file-upload text-warning"></i>
                            }
                            else
                            {
                                <i class="fas fa-tasks text-info"></i>
                            }
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@item.Title</div>
                            <div class="text-muted small">@item.Message</div>
                        </div>
                        <div class="text-muted small ms-2">@item.Timestamp.ToString("MMM dd, hh:mm tt")</div>
                    </div>
                </a>
            }
        }
    </div>
</div>
