@model Academia.Models.ApplicationUser
@{ ViewData["Title"] = Model.FullName; }

<div class="row g-3">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body p-4">
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto mb-3"
                     style="width:80px;height:80px;font-size:2rem">
                    @Model.FullName.Substring(0, 1).ToUpper()
                </div>
                <h5 class="fw-bold">@Model.FullName</h5>
                <p class="text-muted">@Model.Email</p>
                <span class="badge bg-primary">Student</span>
                <div class="text-muted small mt-2">Joined @Model.CreatedAt.ToString("MMMM dd, yyyy")</div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="fas fa-book text-primary me-2"></i>Enrolled Courses</h6>
                @{
                    var enrollments = ViewBag.Enrollments as List<Academia.Models.Enrollment>;
                }
                @if (enrollments == null || !enrollments.Any())
                { <p class="text-muted small">Not enrolled in any courses.</p> }
                else
                {
                    @foreach (var e in enrollments)
                    {
                        <div class="d-flex justify-content-between align-items-center border rounded p-2 mb-2">
                            <div>
                                <strong class="small">@e.Course?.Title</strong>
                                <div class="progress mt-1" style="width:200px;height:6px">
                                    <div class="progress-bar bg-success" style="width:@e.Progress%"></div>
                                </div>
                            </div>
                            <span class="text-muted small">@e.Progress.ToString("F0")% complete</span>
                        </div>
                    }
                }
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <h6 class="fw-bold mb-3"><i class="fas fa-clipboard-check text-warning me-2"></i>Assessment Submissions</h6>
                @{
                    var submissions = ViewBag.Submissions as List<Academia.Models.AssessmentSubmission>;
                }
                @if (submissions == null || !submissions.Any())
                { <p class="text-muted small">No submissions yet.</p> }
                else
                {
                    <table class="table table-sm">
                        <thead><tr><th>Assessment</th><th>Status</th><th>Score</th></tr></thead>
                        <tbody>
                        @foreach (var s in submissions)
                        {
                            <tr>
                                <td class="small">@s.Assessment?.Title</td>
                                <td>
                                    @if (s.Status == "Graded")
                                    { <span class="badge bg-success">Graded</span> }
                                    else
                                    { <span class="badge bg-warning text-dark">Pending</span> }
                                </td>
                                <td class="small">@(s.Score.HasValue ? s.Score + " pts" : "-")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>